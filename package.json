{
  "name": "repair-stackflow-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Repair StackFlow Helper — development execution-core prototype",
  "scripts": {
    "dev": "concurrently -k -n SERVER,UI -c green,cyan \"npm:dev:server\" \"npm:dev:ui\"",
    "dev:server": "tsx watch src/server.ts",
    "dev:ui": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "start": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
